{
  "name": "hide-email-ext",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "bun run typecheck",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "generate-key": "bun run scripts/generate-key.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && bun run zip",
    "ci:release": "bun run scripts/ci-release.ts",
    "prepare": "lefthook install",
    "test": "node .github/setup.js; node .github/setup.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/bun": "^1.2.0",
    "@types/chrome": "^0.1.42",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5",
    "ultracite": "7.7.0",
    "wxt": "^0.20.0"
  }
}
