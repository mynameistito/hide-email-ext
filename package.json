{
  "name": "hide-email-ext",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "typecheck": "tsgo --noEmit",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "generate-key": "bun run ./scripts/generate-key.ts",
    "changeset": "changeset",
    "changeset-add": "bun run ./scripts/add-changeset.ts",
    "version": "changeset version",
    "release": "bun run build && bun run zip",
    "ci:release": "bun run scripts/ci-release.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/chrome": "^0.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "wxt": "^0.20.26"
  }
}
